# =============================================================================
# Generic form endpoint for reusable contact forms
# =============================================================================
# PUBLIC_FORM_ENDPOINT=https://example.com/api/contact

# =============================================================================
# EmDash CMS — encryption key
# =============================================================================
# Generate with: bun run cms:secret   (or: npx emdash secrets generate)
# Losing this value means losing every secret encrypted with it. Keep it safe.
EMDASH_ENCRYPTION_KEY=

# =============================================================================
# Database — Turso / libSQL
# =============================================================================
# Local dev can use a file URL:        TURSO_DATABASE_URL=file:./data.db
# Production (Turso):                   TURSO_DATABASE_URL=libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=file:./data.db
# Auth token is required for remote libsql:// URLs. Leave empty for local file URLs.
TURSO_AUTH_TOKEN=

# =============================================================================
# Media storage — S3-compatible (EmDash media library backend)
# =============================================================================
# EmDash's media library uploads via signed URLs to an S3-compatible store.
# In dev you can leave these blank to fall back to local filesystem storage.
# In production point these at AWS S3, Cloudflare R2, MinIO, etc.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Public base URL for served assets. If you put Cloudinary in front of the
# bucket (fetch/delivery), set this to your Cloudinary delivery URL so public
# image URLs are optimized/transformed on the fly.
S3_PUBLIC_URL=

# =============================================================================
# Cloudinary — asset delivery / optimization (public site)
# =============================================================================
# Used by the site to build optimized delivery URLs for images.
PUBLIC_CLOUDINARY_CLOUD_NAME=
# Only needed if you upload to Cloudinary from server code (not required for
# pure delivery/fetch URLs).
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
