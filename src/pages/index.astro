---
export const prerender = false;
import PageLayout from "~/layouts/PageLayout.astro";
import Hero from "~/components/sections/Hero.astro";
import ServicesGrid from "~/components/sections/ServicesGrid.astro";
import ContentWithKeypoints from "~/components/sections/ContentWithKeypoints.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import FAQs from "~/components/sections/FAQs.astro";
import StructuredData from "~/components/seo/StructuredData.astro";
import { siteConfig } from "~/config/site";
import { getEntry } from "~/lib/content";

// Homepage content comes from the EmDash "pages" collection (slug: "home").
const homeData = await getEntry("pages", "home");
if (!homeData) {
  return new Response("Home content not found", { status: 404 });
}
const sortedSections = homeData.sections;

// Schema markup data
const siteUrl = siteConfig.seo.siteUrl;
const faqSection = sortedSections.find((s: any) => s.section === "FAQs");
const webPageData = {
  name: homeData.metadata?.title || homeData.title,
  description: homeData.metadata?.description || homeData.description,
  url: `${siteUrl}/`,
};
const breadcrumbData = {
  items: [{ name: "Home", url: "/" }],
};
---

<PageLayout metadata={homeData.metadata}>
  <StructuredData type="WebPage" data={webPageData} />
  <StructuredData type="BreadcrumbList" data={breadcrumbData} />
  {faqSection?.faqs && <StructuredData type="FAQPage" data={{ faqs: faqSection.faqs }} />}
  {
    sortedSections.map((section: any, index: number) => {
      // Calculate alternating background (skip Hero which is index 0)
      const sectionIndex = index;
      const isEven = sectionIndex % 2 === 0;
      const sectionBackground = isEven ? "white" : "gradient";
      
      // Hero Section
      if (section.section === "Hero") {
        return (
          <Hero
            tagline={section.eyebrow}
            title={section.title}
            subtitle={section.description}
            image={section.image}
            imageCredit={section.imageCredit}
            actions={
              section.ctaText && section.ctaLink
                ? [
                    {
                      text: section.ctaText,
                      href: section.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      // ServicesGrid Section
      if (section.section === "ServicesGrid" && section.cards) {
        return (
          <ServicesGrid
            title={section.title}
            description={section.description}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            cards={section.cards}
            sectionBackground={sectionBackground}
          />
        );
      }

      // ContentWithKeypoints Section
      if (section.section === "ContentWithKeypoints" && section.keyPoints) {
        return (
          <ContentWithKeypoints
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            keyPoints={section.keyPoints}
            image={section.image}
            sectionBackground={sectionBackground}
          />
        );
      }

      // CTABanner Section (using CallToAction component)
      if (section.section === "CTABanner") {
        return (
          <CallToAction
            title={section.title}
            subtitle={section.description}
            actions={
              section.ctaText && section.ctaLink
                ? [
                    {
                      text: section.ctaText,
                      href: section.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      // FAQs Section
      if (section.section === "FAQs" && section.faqs) {
        return <FAQs title={section.title} faqs={section.faqs} />;
      }

      // Map Section - Now handled globally in BaseLayout
      if (section.section === "Map") {
        return null;
      }

      // FinalCTA Section - Now handled globally in BaseLayout
      if (section.section === "FinalCTA") {
        return null;
      }

      return null;
    })
  }
</PageLayout>
 