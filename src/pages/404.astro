---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { siteConfig } from "~/config/site";

const metadata = {
  title: `404 - Page Not Found | ${siteConfig.business.name}`,
  description: "The page you're looking for doesn't exist.",
  noindex: true,
};
---

<BaseLayout metadata={metadata} hideFinalCTA={true}>
  <section
    class="relative min-h-[70vh] flex items-center justify-center bg-gradient-to-br from-white via-neutral to-white overflow-hidden pb-24"
  >
    <!-- Decorative Elements -->
    <div
      class="absolute top-20 right-1/4 w-72 h-72 bg-primary/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-20 left-1/3 w-96 h-96 bg-accent/5 rounded-full blur-3xl"
    >
    </div>

    <div
      class="max-w-4xl mx-auto px-2 sm:px-3 lg:px-4 text-center relative z-10"
    >
      <!-- Illustration -->
      <div class="mb-8 flex justify-center">
        <div class="w-full max-w-[400px]">
          <svg
            viewBox="0 0 400 320"
            class="h-auto w-full text-primary-dark"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="not-found-accent" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="var(--color-primary-light)" />
                <stop offset="100%" stop-color="var(--color-primary-lighter)" />
              </linearGradient>
            </defs>
            <rect x="30" y="42" width="340" height="236" fill="white" stroke="rgba(13,42,99,0.08)" />
            <rect x="58" y="74" width="284" height="148" fill="rgba(13,42,99,0.04)" />
            <path d="M58 222h284" stroke="rgba(13,42,99,0.08)" stroke-width="2" />
            <text x="200" y="174" text-anchor="middle" font-size="112" font-weight="800" fill="var(--color-primary-dark)">404</text>
            <path d="M108 92h76" stroke="url(#not-found-accent)" stroke-width="8" />
            <path d="M216 92h76" stroke="url(#not-found-accent)" stroke-width="8" />
            <rect x="78" y="244" width="84" height="12" fill="rgba(13,42,99,0.08)" />
            <rect x="172" y="244" width="56" height="12" fill="rgba(13,42,99,0.08)" />
            <rect x="238" y="244" width="84" height="12" fill="rgba(13,42,99,0.08)" />
          </svg>
        </div>
      </div>

      <!-- Content -->
      <div class="relative">
        <div class="inline-block mb-6">
          <div class="h-1 w-16 bg-primary-light mx-auto mb-4"></div>
          <h2
            class="text-3xl sm:text-4xl md:text-5xl font-bold text-primary-light mb-4"
          >
            Page Not Found
          </h2>
          <div class="h-1 w-16 bg-primary-light mx-auto"></div>
        </div>

        <p class="text-lg sm:text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
          Looks like this page took a detour. Don't worry, we'll help you get
          back on track.
        </p>

        <!-- Action Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <a
            href="/"
            class="px-8 py-4 bg-primary-light text-white font-semibold hover:bg-primary-lighter transition-all duration-300 shadow-lg shadow-primary-light/30 inline-flex items-center gap-2"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Back to Home
          </a>
          <a
            href="/contact-us"
            class="px-8 py-4 bg-white text-primary-dark border-2 border-primary-light font-semibold hover:bg-primary-light hover:text-white transition-all duration-300 inline-flex items-center gap-2"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            Contact Us
          </a>
        </div>

        <!-- Quick Links -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm text-gray-500 mb-4">Popular Pages:</p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a
              href="/solutions"
              class="text-sm text-primary-light hover:text-primary-dark transition-colors underline"
            >
              Solutions
            </a>
            <span class="text-gray-300">•</span>
            <a
              href="/indoor-billboards/screen-advertising"
              class="text-sm text-primary-light hover:text-primary-dark transition-colors underline"
            >
              Indoor Billboards
            </a>
            <span class="text-gray-300">•</span>
            <a
              href="/about-us"
              class="text-sm text-primary-light hover:text-primary-dark transition-colors underline"
            >
              About Us
            </a>
            <span class="text-gray-300">•</span>
            <a
              href="/locations"
              class="text-sm text-primary-light hover:text-primary-dark transition-colors underline"
            >
              Locations
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
