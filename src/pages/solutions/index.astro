---
export const prerender = false;
import PageLayout from "~/layouts/PageLayout.astro";
import Hero from "~/components/sections/Hero.astro";
import FeaturesWithImage from "~/components/sections/FeaturesWithImage.astro";
import FeaturesSection from "~/components/sections/FeaturesSection.astro";
import StructuredData from "~/components/seo/StructuredData.astro";
import { siteConfig } from "~/config/site";
import { getEntry, buildMetadata } from "~/lib/content";

// Solutions index content comes from the EmDash "pages" collection.
const solutionsData = await getEntry("pages", "solutions");
if (!solutionsData) {
  return new Response("Solutions content not found", { status: 404 });
}
const sections = solutionsData.sections;
const metadata = buildMetadata(solutionsData);

// Schema markup data
const siteUrl = siteConfig.seo.siteUrl;
const webPageData = {
  name: metadata.title,
  description: metadata.description,
  url: `${siteUrl}/solutions`,
};
const breadcrumbData = {
  items: [
    { name: "Home", url: "/" },
    { name: "Solutions", url: "/solutions" },
  ],
};
const faqSection = sections.find((s: any) => s.section === "FAQs") as any;
---

<PageLayout metadata={metadata}>
  <StructuredData type="WebPage" data={webPageData} />
  <StructuredData type="BreadcrumbList" data={breadcrumbData} />
  {faqSection?.faqs && <StructuredData type="FAQPage" data={{ faqs: (faqSection as any).faqs }} />}
  {
    sections.map((section: any, index: number) => {
      // Calculate alternating background (skip Hero which is index 0)
      const sectionIndex = index;
      const isEven = sectionIndex % 2 === 0;
      const sectionBackground = isEven ? "white" : "gradient";
      
      // Hero Section
      if (section.section === "Hero") {
        return (
          <Hero
            tagline={section.eyebrow}
            title={section.title}
            subtitle={section.description}
            image={section.image}
            imageCredit={section.imageCredit}
            actions={
              section.ctaText && section.ctaLink
                ? [
                    {
                      text: section.ctaText,
                      href: section.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      // Features Sections
      if (
        section.section === "FeaturesWithImage" ||
        section.section === "FeaturesSection"
      ) {
        if (!section.features) return null;

        if (section.section === "FeaturesWithImage") {
          return (
            <FeaturesWithImage
              eyebrow={section.eyebrow}
              title={section.title}
              description={section.description}
              cards={section.features}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
              sectionBackground={sectionBackground}
            />
          );
        }

        return (
          <FeaturesSection
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            features={section.features}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            sectionBackground={sectionBackground}
          />
        );
      }

      return null;
    })
  }
</PageLayout>
