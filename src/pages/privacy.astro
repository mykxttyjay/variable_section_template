the ---
import BaseLayout from "~/layouts/BaseLayout.astro";
import StructuredData from "~/components/seo/StructuredData.astro";
import { SITE_NAME } from "~/lib/config";
import { siteConfig } from "~/config/site";

const metadata = {
  title: "Privacy Policy",
  description: "Read the Variable Section Privacy Policy to learn how we collect, use, and protect your personal information when you visit and interact with our website.",
  keywords: "", // Explicitly no keywords for legal pages
};

// Schema markup data
const siteUrl = siteConfig.seo.siteUrl;
const webPageData = {
  name: metadata.title,
  description: metadata.description,
  url: `${siteUrl}/privacy`,
};
const breadcrumbData = {
  items: [
    { name: "Home", url: "/" },
    { name: "Privacy Policy", url: "/privacy" },
  ],
};
---

<BaseLayout metadata={metadata} hideMapSection={true} hideFinalCTA={true}>
  <StructuredData type="WebPage" data={webPageData} />
  <StructuredData type="BreadcrumbList" data={breadcrumbData} />
  <div class="bg-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-2 sm:px-3 lg:px-4">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-primary-dark mb-4">
          Our Privacy Policy
        </h1>
        <p class="text-gray-600">Last Updated: March 28, 2026</p>
      </div>

      <!-- Content -->
      <div class="prose prose-lg max-w-none">
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            1. Introduction
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            {SITE_NAME} ("we," "us," or "our") is committed to protecting your
            privacy. This Privacy Policy explains how we collect, use, and
            safeguard your information when you visit our website
            ("Site").
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            2. Information We Collect
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We may collect the following types of information:
          </p>

          <h3 class="text-xl font-semibold text-primary-dark mb-3 mt-6">
            Information You Provide
          </h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            When you submit an inquiry through our contact form, we may collect:
          </p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>Your name</li>
            <li>Email address</li>
            <li>Phone number</li>
            <li>Business name</li>
            <li>Details about your inquiry or the services you are interested in</li>
          </ul>

          <h3 class="text-xl font-semibold text-primary-dark mb-3 mt-6">
            Information Collected Automatically
          </h3>
          <p class="text-gray-700 leading-relaxed mb-2">
            When you visit our Site, certain information is collected
            automatically through Google Analytics and standard web technologies:
          </p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>IP address (anonymized)</li>
            <li>Browser type and version</li>
            <li>Device type and operating system</li>
            <li>Pages visited and time spent on each page</li>
            <li>Referring website or source</li>
            <li>General geographic location (city/region level)</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            3. How We Use Your Information
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We use the information we collect for the following purposes:
          </p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>Responding to your inquiries and contact form submissions</li>
            <li>Communicating with you about our services</li>
            <li>Understanding how visitors use our Site so we can improve it</li>
            <li>Analyzing website traffic and usage patterns</li>
            <li>Complying with legal obligations</li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            4. Third-Party Services
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We do not sell your personal information. Our Site uses the
            following third-party services that may collect or process data:
          </p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>
              <strong>Google Analytics:</strong> Collects anonymized usage data
              to help us understand Site traffic and visitor behavior. Google's
              privacy policy applies to this data. You can opt out of Google
              Analytics by installing the
              <a
                href="https://tools.google.com/dlpage/gaoptout"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary underline hover:text-primary-dark"
              >Google Analytics Opt-out Browser Add-on</a>.
            </li>
            <li>
              <strong>Contact Form Provider:</strong> Our contact form is powered
              by a third-party service that processes and delivers your
              submissions to us. The information you provide in the form is
              transmitted through their platform.
            </li>
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            5. Cookies and Tracking Technologies
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Our Site uses cookies, small text files stored on your device, primarily
            through Google Analytics to understand how visitors interact with our
            Site. These cookies help us analyze traffic patterns and improve the
            user experience.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            You can control or disable cookies through your browser settings.
            Please note that disabling cookies may affect certain features of the
            Site.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            6. Data Security
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We take reasonable measures to protect the information collected
            through our Site. However, no method of transmission over the
            Internet is 100% secure, and we cannot guarantee absolute security
            of your data.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            7. Data Retention
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Contact form submissions are retained for as long as necessary to
            respond to your inquiry and for our legitimate business purposes.
            Analytics data is retained according to our Google Analytics
            configuration settings.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            8. Your Privacy Rights
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Under California law and other applicable privacy regulations, you
            may have the right to:
          </p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2 mb-4">
            <li>Know what personal information we have collected about you</li>
            <li>Request correction of inaccurate information</li>
            <li>Request deletion of your personal information</li>
            <li>Opt out of the sale of your personal information (we do not sell your data)</li>
          </ul>
          <p class="text-gray-700 leading-relaxed mb-4">
            To exercise any of these rights, please contact us using the
            information provided below.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            9. External Links
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Our Site may contain links to third-party websites, including social
            media platforms. We are not responsible for the privacy practices of
            these external sites and encourage you to review their privacy
            policies.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            10. Children's Privacy
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Our Site is not directed to individuals under the age of 16. We do
            not knowingly collect personal information from children. If you
            believe we have inadvertently collected information from a child,
            please contact us so we can promptly delete it.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            11. Changes to This Privacy Policy
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We may update this Privacy Policy from time to time. Changes will be
            posted on this page with an updated "Last Updated" date. Your
            continued use of the Site after any changes constitutes your
            acceptance of the revised policy.
          </p>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-bold text-primary-dark mb-4">
            12. Contact Us
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            If you have any questions about this Privacy Policy or how we handle
            your information, please contact us:
          </p>
          <ul class="list-none text-gray-700 space-y-2">
            <li><strong>Email:</strong> {siteConfig.contact.email}</li>
            <li><strong>Phone:</strong> {siteConfig.contact.phoneFormatted}</li>
            <li><strong>Address:</strong> {siteConfig.location.fullAddress}</li>
          </ul>
        </section>
      </div>

      <!-- Back to Home -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <a
          href="/"
          class="inline-flex items-center text-primary hover:text-primary-dark transition"
        >
          <svg
            class="w-5 h-5 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
