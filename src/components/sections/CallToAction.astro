---
interface Props {
  title?: string;
  subtitle?: string;
  actions?: Array<{
    text: string;
    href: string;
    variant?: "primary" | "secondary";
  }>;
}

const {
  title = "Ready to get started?",
  subtitle = "Contact us today to learn how we can help grow your business.",
  actions = [{ text: "Get In Touch", href: "/contact-us", variant: "primary" }],
} = Astro.props;
---

<section class="py-20 md:py-28 bg-gradient-to-br from-primary-darker via-primary-dark to-slate-900 text-white relative overflow-hidden">
  <!-- Decorative Glow Blobs -->
  <div class="glow-orb glow-orb-green w-[600px] h-[600px] -top-40 -right-40 opacity-20"></div>
  <div class="glow-orb glow-orb-mint w-[500px] h-[500px] -bottom-40 -left-40 opacity-15"></div>
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4">
    <div class="relative z-10 text-center" data-animate="fade-right">
      <h2 class="text-3xl md:text-5xl font-bold mb-4" set:html={title}></h2>
      <p
        class="text-lg md:text-xl text-gray-200 mb-8 max-w-3xl mx-auto"
        set:html={subtitle}
      />

      {
        actions.length > 0 && (
          <div class="flex flex-wrap gap-4 justify-center">
            {actions.map((action) => (
              <a
                href={action.href}
                class={
                    action.variant === "secondary"
                      ? "btn-clipped inline-flex items-center gap-2 px-8 py-3.5 text-xs font-bold uppercase tracking-wider border border-slate-700 bg-white/5 backdrop-blur-sm text-white hover:bg-white hover:text-slate-900 transition-all duration-300"
                      : "btn-clipped inline-flex items-center gap-2 px-8 py-3.5 text-xs font-bold uppercase tracking-wider bg-primary-light text-white hover:bg-primary-lighter transition-all duration-300"
                }
              >
                {action.text}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
