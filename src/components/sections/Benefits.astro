---
interface Props {
  title?: string;
  description?: string;
  benefits?: Array<{
    title: string;
    description: string;
  }>;
}

const { title, description, benefits = [] } = Astro.props;
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      title && (
        <div class="text-center mb-12" data-animate="fade-up">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            {title}
          </h2>
          {description && (
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">{description}</p>
          )}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate-stagger>
      {
        benefits.map((benefit) => (
          <div class="flex gap-4 p-6 border border-gray-200 hover:border-primary-light hover:shadow-md transition-all">
            <div class="flex-shrink-0">
              <svg
                class="w-6 h-6 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {benefit.title}
              </h3>
              <p class="text-gray-600">{benefit.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
