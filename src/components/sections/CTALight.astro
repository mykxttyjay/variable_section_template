---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  keyPoints?: string[];
}

const { title, description, ctaText, ctaLink, keyPoints = [] } = Astro.props;
---

<section class="py-12 sm:py-16 md:py-24 text-white relative overflow-hidden">
  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/chino-hills-ca-bg.avif');"
  >
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-darker/90 via-primary-dark/85 to-slate-900/90"></div>

  <!-- Decorative Glow Blobs -->
  <div class="glow-orb glow-orb-green w-[600px] h-[600px] -top-40 -right-40 opacity-20 relative z-[1]"></div>
  <div class="glow-orb glow-orb-mint w-[500px] h-[500px] -bottom-40 -left-40 opacity-15 relative z-[1]"></div>
  
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4 relative z-10">
    <div
      class="max-w-5xl mx-auto"
      data-animate="zoom-in"
    >
      <div class="mb-8 sm:mb-12">
        {
          title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-4 sm:mb-6 text-center">
              {title}
            </h2>
          )
        }
        {
          description && (
            <p
              class="text-base sm:text-lg md:text-xl text-gray-200 mb-6 sm:mb-8 max-w-3xl mx-auto text-center"
              set:html={description}
            />
          )
        }
      </div>

      {
        keyPoints.length > 0 && (
          <div class="max-w-4xl mx-auto mb-8 sm:mb-12">
            <div
              class="grid grid-cols-1 md:grid-cols-2 gap-4"
              data-animate-stagger
            >
              {keyPoints.map((point) => (
                <div class="flex items-start gap-3 bg-white/10 p-4 rounded-lg border border-white/20 backdrop-blur-sm">
                  <div class="flex-shrink-0 w-6 h-6 bg-primary-light text-white flex items-center justify-center text-xs font-bold rounded">
                    ✓
                  </div>
                  <span class="text-sm sm:text-base text-gray-100 flex-1">
                    {point}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )
      }

      {
        ctaText && ctaLink && (
          <div class="text-center">
            <a
              href={ctaLink}
              class="btn-modern"
            >
              <span class="btn-modern-content">{ctaText}</span>
              <span class="btn-modern-icon">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </span>
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
