---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  keyPoints?: string[];
}

const { title, description, ctaText, ctaLink, keyPoints = [] } = Astro.props;
---

<section class="py-12 sm:py-16 md:py-24 bg-neutral-light">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 lg:px-6">
    <div
      class="bg-white p-8 md:p-12 border-t-4 border-primary-light shadow-lg"
      data-animate="zoom-in"
    >
      <div class="max-w-3xl mx-auto text-center mb-8 sm:mb-12">
        {
          title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4 sm:mb-6">
              {title}
            </h2>
          )
        }
        {
          description && (
            <p
              class="text-base sm:text-lg md:text-xl text-gray-600 mb-6 sm:mb-8"
              set:html={description}
            />
          )
        }
      </div>

      {
        keyPoints.length > 0 && (
          <div class="max-w-4xl mx-auto mb-8 sm:mb-12">
            <div
              class="grid grid-cols-1 md:grid-cols-2 gap-4"
              data-animate-stagger
            >
              {keyPoints.map((point) => (
                <div class="flex items-start gap-3 bg-gray-50 p-4">
                  <div class="flex-shrink-0 w-6 h-6 bg-primary text-white flex items-center justify-center text-xs font-bold">
                    ✓
                  </div>
                  <span class="text-sm sm:text-base text-gray-700 flex-1">
                    {point}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )
      }

      {
        ctaText && ctaLink && (
          <div class="text-center">
            <a
              href={ctaLink}
              class="btn-clipped inline-flex items-center gap-2 px-8 py-4 bg-primary text-white text-xs font-bold uppercase tracking-wider hover:bg-primary-dark transition-all duration-300"
            >
              {ctaText}
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
