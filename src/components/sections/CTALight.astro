---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  keyPoints?: string[];
}

const { title, description, ctaText, ctaLink, keyPoints = [] } = Astro.props;
---

<section style="background-color: #f9f9f7; background-image: radial-gradient(ellipse at 0% 0%, rgba(0,107,114,0.10) 0%, transparent 65%), radial-gradient(ellipse at 100% 100%, rgba(0,173,181,0.09) 0%, transparent 65%), radial-gradient(ellipse at 80% 10%, rgba(0,107,114,0.06) 0%, transparent 50%);" class="py-12 sm:py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-2 sm:px-3 lg:px-4">
    <div
      class="max-w-3xl mx-auto"
      data-animate="zoom-in"
    >
      <div class="mb-8 sm:mb-12">
        {
          title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4 sm:mb-6 text-center">
              {title}
            </h2>
          )
        }
        {
          description && (
            <p
              class="text-base sm:text-lg md:text-xl text-gray-600 mb-6 sm:mb-8 max-w-3xl mx-auto text-center"
              set:html={description}
            />
          )
        }
      </div>

      {
        keyPoints.length > 0 && (
          <div class="max-w-4xl mx-auto mb-8 sm:mb-12">
            <div
              class="grid grid-cols-1 md:grid-cols-2 gap-4"
              data-animate-stagger
            >
              {keyPoints.map((point) => (
                <div class="flex items-start gap-3 bg-gray-50 p-4">
                  <div class="flex-shrink-0 w-6 h-6 bg-primary text-white flex items-center justify-center text-xs font-bold">
                    ✓
                  </div>
                  <span class="text-sm sm:text-base text-gray-700 flex-1">
                    {point}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )
      }

      {
        ctaText && ctaLink && (
          <div class="text-center">
            <a
              href={ctaLink}
              class="btn-modern"
            >
              <span class="btn-modern-content">{ctaText}</span>
              <span class="btn-modern-icon">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </span>
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
