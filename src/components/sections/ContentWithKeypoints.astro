---
interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  image?: string;
  imageLarge?: string;
  keyPoints?: string[];
}

const {
  title,
  eyebrow,
  description,
  ctaText,
  ctaLink,
  image,
  imageLarge,
  keyPoints = [],
} = Astro.props;
---

<section class="py-12 sm:py-16 md:py-24 bg-white relative overflow-hidden">
  <!-- Decorative Glow Blob -->
  <div class="glow-orb glow-orb-green w-[400px] h-[400px] -top-20 -right-20 opacity-10"></div>
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-center">
      <div class="order-2 lg:order-1 lg:col-span-3" data-animate="fade-right">
        {
          eyebrow && (
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-4 h-4 text-primary-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="font-bold text-xs sm:text-sm uppercase tracking-widest text-primary">
                {eyebrow}
              </span>
            </div>
          )
        }
        {
          title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-3">
              {title}
            </h2>
            <div class="h-1.5 w-24 rounded-full bg-gradient-to-r from-primary-light to-transparent mb-6 sm:mb-8"></div>
          )
        }
        {
          description && (
            <p
              class="text-gray-600 mb-6 leading-relaxed"
              style="font-size: 19px;"
              set:html={description}
            />
          )
        }
        {
          keyPoints.length > 0 && (
            <div class="mb-6 sm:mb-8">
              <ul class="space-y-4" data-animate-stagger>
                {keyPoints.map((point) => (
                  <li class="flex items-center gap-4">
                    <div class="flex-shrink-0 w-5 h-5 bg-primary-light flex items-center justify-center" style="clip-path: polygon(0% 0%, calc(100% - 6px) 0%, 100% 6px, 100% 100%, 0% 100%);">
                      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                    </div>
                    <span class="text-sm sm:text-base text-gray-700 font-medium flex-1">
                      {point}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        {
          ctaText && ctaLink && (
            <a
              href={ctaLink}
              class="btn-clipped inline-flex items-center gap-2 px-8 py-3 bg-primary-light text-white text-xs font-bold uppercase tracking-wider transition-all duration-300 hover:bg-primary-lighter"
            >
              {ctaText}
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>
          )
        }
      </div>
      {
        image && (
          <div
            class="hidden lg:block relative overflow-hidden order-1 lg:order-2 lg:col-span-2 self-stretch"
            data-animate="fade-left"
          >
            <picture>
              <source media="(min-width: 768px)" srcset={imageLarge || image} />
              <img
                src={image}
                alt={title || "Venue Network"}
                class="w-full h-full object-cover"
                width="400"
                height="500"
                loading="lazy"
              />
            </picture>
          </div>
        )
      }
    </div>
  </div>
</section>
