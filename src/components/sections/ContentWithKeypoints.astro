---
interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  image?: string;
  imageLarge?: string;
  keyPoints?: string[];
}

const {
  title,
  eyebrow,
  description,
  ctaText,
  ctaLink,
  image,
  imageLarge,
  keyPoints = [],
} = Astro.props;
---

<section class="py-12 sm:py-16 md:py-24 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">
  <!-- Decorative Glow Blob -->
  <div class="glow-orb glow-orb-green w-[400px] h-[400px] -top-20 -right-20 opacity-10"></div>
  <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-center">
      <div class="order-2 lg:order-1 lg:col-span-3" data-animate="fade-right">
        {
          eyebrow && (
            <div class="flex items-center gap-2 mb-4">
              <div class="h-1 w-10 bg-gradient-to-r from-primary-light to-secondary rounded-full" />
              <span class="font-bold text-xs sm:text-sm uppercase tracking-widest text-primary">
                {eyebrow}
              </span>
            </div>
          )
        }
        {
          title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4 sm:mb-6">
              {title}
            </h2>
          )
        }
        {
          description && (
            <p
              class="text-base sm:text-lg text-gray-600 mb-6 leading-relaxed"
              set:html={description}
            />
          )
        }
        {
          keyPoints.length > 0 && (
            <div class="glass-panel p-8 rounded-2xl border border-slate-200/50 mb-6 sm:mb-8 shadow-sm">
              <ul class="space-y-3" data-animate-stagger>
                {keyPoints.map((point) => (
                  <li class="flex items-start gap-3">
                    <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gradient-to-tr from-primary-light to-secondary text-white flex items-center justify-center text-xs font-semibold mt-0.5 shadow-sm">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                    </div>
                    <span class="text-sm sm:text-base text-gray-700 flex-1">
                      {point}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        {
          ctaText && ctaLink && (
            <a
              href={ctaLink}
              class="btn-clipped btn-premium inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-primary-light to-secondary text-white text-xs font-bold uppercase tracking-wider transition-all duration-300"
            >
              {ctaText}
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>
          )
        }
      </div>
      {
        image && (
          <div
            class="hidden lg:block relative overflow-hidden order-1 lg:order-2 lg:col-span-2"
            data-animate="fade-left"
          >
            <picture>
              <source media="(min-width: 768px)" srcset={imageLarge || image} />
              <img
                src={image}
                alt={title || "Venue Network"}
                class="w-full h-auto object-cover rounded-3xl shadow-xl shadow-slate-200/50 aspect-[4/5] hover:scale-[1.02] transition-transform duration-500"
                width="400"
                height="500"
                loading="lazy"
              />
            </picture>
          </div>
        )
      }
    </div>
  </div>
</section>
