---
interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  image?: string;
  imageCredit?: string;
  actions?: Array<{
    text: string;
    href: string;
    variant?: "primary" | "secondary";
  }>;
}

const {
  title = "Welcome to Your Brand",
  subtitle = "Elevate your business with our comprehensive marketing solutions",
  tagline,
  image,
  imageCredit,
  actions = [],
} = Astro.props;
---

<section class="relative overflow-hidden min-h-[85vh] flex items-stretch">

  <!-- Full-bleed background image (right side shows through) -->
  <div class="absolute inset-0 z-0" id="hero-parallax-bg">
    {image ? (
      <img
        src={image}
        alt="Hero background"
        class="w-full h-full object-cover object-center"
        style="transform: translateY(0px);"
        loading="eager"
        fetchpriority="high"
        width="1600"
        height="900"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-primary-dark to-primary"></div>
    )}
  </div>

  <!-- LEFT: White angled panel covering the left side -->
  <div
    class="absolute inset-y-0 left-0 z-10 w-[65%] hero-panel-animate"
    style="clip-path: polygon(0% 0%, 100% 0%, 82% 100%, 0% 100%);"
  >
    <div class="w-full h-full bg-white/75"></div>
  </div>



  <!-- Content: left-aligned inside the white panel -->
  <div class="relative z-30 w-full flex items-center min-h-[85vh]">
    <div class="w-full max-w-7xl mx-auto px-2 sm:px-3 lg:px-4 py-24 md:py-32">
      <div class="w-full lg:w-[48%]">

        {tagline && (
          <div class="flex items-center gap-3 mb-6">
            <span class="inline-flex items-center gap-2 bg-primary-light/10 border border-primary-light/30 px-4 py-1.5">
              <svg class="w-4 h-4 text-primary-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
              </svg>
              <span class="font-bold text-xs uppercase tracking-[0.2em] text-primary-light">
                {tagline}
              </span>
            </span>
          </div>
        )}

        <h1 class="font-bold text-primary-dark mb-6 leading-[1.1]" style="font-size: 72px; max-width: 650px;">
          {title}
        </h1>

        <div class="h-1 w-20 bg-primary-light mb-8"></div>

        <p class="text-gray-600 mb-10 leading-relaxed" style="font-size: 20px;" set:html={subtitle}></p>

        {actions.length > 0 && (
          <div class="flex flex-wrap gap-4">
            {actions.map((action) => (
              <a
                href={action.href}
                class={
                  action.variant === "secondary"
                    ? "btn-clipped px-8 py-3 text-xs font-bold uppercase tracking-wider border-2 border-primary text-primary hover:bg-primary hover:text-white transition-all duration-300 inline-flex items-center gap-2"
                    : "btn-clipped px-8 py-3 text-xs font-bold uppercase tracking-wider bg-primary-light text-white hover:bg-primary-lighter transition-all duration-300 inline-flex items-center gap-2"
                }
              >
                {action.text}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Image credit -->
  {imageCredit && (
    <span
      class="absolute bottom-2 right-3 z-30 text-[9px] text-white/40 [&_a]:underline [&_a]:hover:text-white/60 [&_a]:transition-colors"
      set:html={imageCredit}
    />
  )}

</section>

<script>
  // Parallax scrolling effect for hero background
  function initHeroParallax() {
    const parallaxBg = document.getElementById('hero-parallax-bg');
    const heroSection = parallaxBg?.closest('section');
    
    if (!parallaxBg || !heroSection) return;
    
    const img = parallaxBg.querySelector('img');
    if (!img) return;

    let ticking = false;

    function updateParallax() {
      const rect = heroSection.getBoundingClientRect();
      const scrolled = window.scrollY;
      
      // Only apply parallax when section is in view
      if (rect.bottom > 0 && rect.top < window.innerHeight) {
        // Parallax factor: 0.5 means background moves at half speed (adjust for different effects)
        const yPos = scrolled * 0.5;
        img.style.transform = `translateY(${yPos}px)`;
      }
      
      ticking = false;
    }

    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    // Throttled scroll listener
    window.addEventListener('scroll', requestTick, { passive: true });
    
    // Initial call
    updateParallax();
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroParallax);
  } else {
    initHeroParallax();
  }

  // Re-initialize on Astro page transitions (if using View Transitions)
  document.addEventListener('astro:page-load', initHeroParallax);
</script>
