---
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  features?: any[];
  ctaText?: string;
  ctaLink?: string;
  sectionBackground?: "gradient" | "white";
  carousel?: boolean;
  cardsPerBatch?: number;
}

const {
  eyebrow,
  title,
  description,
  features = [],
  ctaText,
  ctaLink,
  sectionBackground = "white",
  carousel = false,
  cardsPerBatch = 3,
} = Astro.props;

const bgClass = sectionBackground === "white" ? "bg-white" : "";
const bgStyle = sectionBackground === "gradient" 
  ? "background-color: #f9f9f7; background-image: radial-gradient(ellipse at 0% 0%, rgba(0,107,114,0.10) 0%, transparent 65%), radial-gradient(ellipse at 100% 100%, rgba(0,173,181,0.09) 0%, transparent 65%);"
  : "";

// Split features into batches for carousel
const featureBatches = carousel ? features.reduce((acc: any[], feature: any, index: number) => {
  const batchIndex = Math.floor(index / cardsPerBatch);
  if (!acc[batchIndex]) acc[batchIndex] = [];
  acc[batchIndex].push(feature);
  return acc;
}, []) : [features];

const showCarousel = carousel && featureBatches.length > 1;
---

<section class={`py-12 sm:py-16 md:py-24 ${bgClass}`} style={bgStyle}>
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4">
    {(eyebrow || title || description) && (
      <div class="text-center mb-8 sm:mb-12" data-animate="fade-up">
        {eyebrow && (
          <div class="flex items-center justify-center gap-2 mb-2">
            <div class="h-px w-12 bg-primary" />
            <p class="text-xs sm:text-sm font-semibold uppercase tracking-wide text-primary">
              {eyebrow}
            </p>
          </div>
        )}
        {title && (
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4">
            {title}
          </h2>
        )}
        {description && (
          <p
            class="text-base sm:text-lg md:text-xl text-gray-600"
            set:html={description}
          />
        )}
      </div>
    )}

    {showCarousel ? (
      <div class="relative px-12" data-features-carousel-root data-cards-per-batch={String(cardsPerBatch)}>
        {/* Navigation Buttons */}
        <button
          class="absolute left-0 top-1/2 -translate-y-1/2 bg-primary text-white p-3 hover:bg-primary-dark transition z-10 rounded-lg"
          data-carousel-prev
          aria-label="Previous batch"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        {/* Carousel Container */}
        <div class="overflow-hidden">
          <div class="flex transition-all duration-500 ease-in-out" data-carousel-track>
            {featureBatches.map((batch: any[]) => (
              <div class="w-full flex-shrink-0">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                  {batch.map((feature: any) => (
                    <div class="group relative p-8 bg-gray-50 hover:bg-white transition-all duration-300 flex flex-col items-start gap-5 border-2 border-gray-300 hover:border-primary-light shadow-lg hover:shadow-xl hover:-translate-y-1 rounded-3xl overflow-hidden">
                      {feature.icon && (
                        <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-primary-light to-primary text-white flex items-center justify-center group-hover:scale-125 transition-transform duration-300 rounded-lg shadow-lg">
                          <Icon name={feature.icon} class="w-8 h-8" />
                        </div>
                      )}
                      <div class="flex-1 w-full">
                        <h3 class="text-xl font-bold text-primary-dark mb-3 group-hover:text-primary transition-colors duration-200">
                          {feature.link ? (
                            <a href={feature.link} class="after:absolute after:inset-0 hover:underline">
                              {feature.title}
                            </a>
                          ) : (
                            feature.title
                          )}
                        </h3>
                        <p class="text-gray-600 text-base leading-relaxed group-hover:text-gray-700 transition-colors duration-200" set:html={feature.description} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <button
          class="absolute right-0 top-1/2 -translate-y-1/2 bg-primary text-white p-3 hover:bg-primary-dark transition z-10 rounded-lg"
          data-carousel-next
          aria-label="Next batch"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        {/* Dot Indicators */}
        <div class="flex justify-center gap-2 mt-8">
          {featureBatches.map((_, index: number) => (
            <button
              class="w-3 h-3 bg-gray-300 hover:bg-primary transition rounded-full"
              data-carousel-dot={index}
              aria-label={`Go to batch ${index + 1}`}
            />
          ))}
        </div>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature: any) => (
          <div class="group relative p-8 bg-gray-50 hover:bg-white transition-all duration-300 flex flex-col items-start gap-5 border-2 border-gray-300 hover:border-primary-light shadow-lg hover:shadow-xl hover:-translate-y-1 rounded-3xl overflow-hidden">
            {feature.icon && (
              <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-primary-light to-primary text-white flex items-center justify-center group-hover:scale-125 transition-transform duration-300 rounded-lg shadow-lg">
                <Icon name={feature.icon} class="w-8 h-8" />
              </div>
            )}
            <div class="flex-1 w-full">
              <h3 class="text-xl font-bold text-primary-dark mb-3 group-hover:text-primary transition-colors duration-200">
                {feature.link ? (
                  <a href={feature.link} class="after:absolute after:inset-0 hover:underline">
                    {feature.title}
                  </a>
                ) : (
                  feature.title
                )}
              </h3>
              <p class="text-gray-600 text-base leading-relaxed group-hover:text-gray-700 transition-colors duration-200" set:html={feature.description} />
            </div>
          </div>
        ))}
      </div>
    )}

    {ctaText && ctaLink && (
      <div class="text-center mt-8 sm:mt-12" data-animate="fade-up" data-animate-delay="200">
        <a
          href={ctaLink}
          class="inline-block px-6 py-3 sm:px-8 sm:py-4 bg-primary text-white font-medium hover:bg-primary-dark transition text-sm sm:text-base"
        >
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>

<script>
  function initFeaturesCarousel() {
    const carousels = document.querySelectorAll("[data-features-carousel-root]");
    if (!carousels.length) return;

    carousels.forEach((carousel) => {
      const el = carousel as HTMLElement;
      const htmlEl = el as any;
      if (htmlEl.dataset.carouselInitialized === "true") return;

      const track = el.querySelector("[data-carousel-track]") as HTMLElement | null;
      const prevBtn = el.querySelector("[data-carousel-prev]") as HTMLButtonElement | null;
      const nextBtn = el.querySelector("[data-carousel-next]") as HTMLButtonElement | null;
      const dots = el.querySelectorAll("[data-carousel-dot]");

      if (!track || !prevBtn || !nextBtn || !dots.length) return;

      htmlEl.dataset.carouselInitialized = "true";

      let currentIndex = 0;
      const totalBatches = dots.length;

      function updateCarousel() {
        const offset = -(currentIndex * 100);
        track!.style.opacity = "0";
        track!.style.transform = `translateX(${offset}%)`;
        
        setTimeout(() => {
          track!.style.opacity = "1";
        }, 100);

        dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.remove("bg-gray-300");
            dot.classList.add("bg-primary");
          } else {
            dot.classList.remove("bg-primary");
            dot.classList.add("bg-gray-300");
          }
        });

        (prevBtn as any).disabled = currentIndex === 0;
        (nextBtn as any).disabled = currentIndex === totalBatches - 1;
      }

      function nextSlide() {
        if (currentIndex < totalBatches - 1) {
          currentIndex++;
          updateCarousel();
        }
      }

      function prevSlide() {
        if (currentIndex > 0) {
          currentIndex--;
          updateCarousel();
        }
      }

      prevBtn!.addEventListener("click", prevSlide);
      nextBtn!.addEventListener("click", nextSlide);

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          currentIndex = index;
          updateCarousel();
        });
      });

      updateCarousel();
    });
  }

  document.addEventListener("astro:page-load", initFeaturesCarousel);
</script>
