---
interface Props {
  title?: string;
  subtitle?: string;
  actions?: Array<{
    text: string;
    href: string;
    variant?: "primary" | "secondary";
  }>;
}

const {
  title = "Ready to get started?",
  subtitle = "Contact us today to learn how we can help grow your business.",
  actions = [{ text: "Get In Touch", href: "/contact-us", variant: "primary" }],
} = Astro.props;
---

<section class="relative py-20 md:py-28 text-white overflow-hidden">
  <!-- Lightweight Background Image -->
  <div
    id="final-cta-parallax-bg"
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/home-cta.avif'); transform: translateY(0px) scale(1.02);"
  >
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-primary-dark/85"></div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4 relative z-10">
    <div data-animate="fade-right">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        {title}
      </h2>
      <p
        class="text-lg md:text-xl text-gray-200 mb-8 max-w-2xl"
        set:html={subtitle}
      />

      {
        actions.length > 0 && (
          <div class="flex flex-wrap gap-4">
            {actions.map((action) => (
              <a
                href={action.href}
                class={
                  action.variant === "secondary"
                    ? "btn-modern opacity-80"
                    : "btn-modern"
                }
              >
                <span class="btn-modern-content">{action.text}</span>
                <span class="btn-modern-icon">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>


<script>
  // Parallax scrolling effect for Final CTA background
  function initFinalCTAParallax() {
    const parallaxBg = document.getElementById('final-cta-parallax-bg');
    const ctaSection = parallaxBg?.closest('section');
    
    if (!parallaxBg || !ctaSection) return;

    let ticking = false;

    function updateParallax() {
      const rect = ctaSection.getBoundingClientRect();
      const sectionTop = rect.top;
      const sectionHeight = rect.height;
      const windowHeight = window.innerHeight;
      
      // Only apply parallax when section is in viewport
      if (rect.bottom > 0 && sectionTop < windowHeight) {
        // Calculate parallax based on section position in viewport
        const scrollProgress = (windowHeight - sectionTop) / (windowHeight + sectionHeight);
        const yPos = (scrollProgress - 0.5) * 100; // Range from -50 to 50
        
        parallaxBg.style.transform = `translateY(${yPos}px) scale(1.02)`;
      }
      
      ticking = false;
    }

    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    // Throttled scroll listener
    window.addEventListener('scroll', requestTick, { passive: true });
    window.addEventListener('resize', requestTick, { passive: true });
    
    // Initial call
    updateParallax();
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFinalCTAParallax);
  } else {
    initFinalCTAParallax();
  }

  // Re-initialize on Astro page transitions (if using View Transitions)
  document.addEventListener('astro:page-load', initFinalCTAParallax);
</script>
