---
interface Props {
  title?: string;
  subtitle?: string;
  actions?: Array<{
    text: string;
    href: string;
    variant?: "primary" | "secondary";
  }>;
}

const {
  title = "Ready to get started?",
  subtitle = "Contact us today to learn how we can help grow your business.",
  actions = [{ text: "Get In Touch", href: "/contact-us", variant: "primary" }],
} = Astro.props;
---

<section class="relative py-20 md:py-28 text-white overflow-hidden">
  <!-- Lightweight Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/chino-hills-ca-bg.avif'); transform: scale(1.02);"
  >
  </div>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-primary-dark/85"></div>

  <!-- Content -->
  <div class="max-w-5xl mx-auto px-3 sm:px-4 lg:px-6 relative z-10">
    <div class="border-l-4 border-primary-light pl-8" data-animate="fade-right">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        {title}
      </h2>
      <p
        class="text-lg md:text-xl text-gray-200 mb-8 max-w-2xl"
        set:html={subtitle}
      />

      {
        actions.length > 0 && (
          <div class="flex flex-wrap gap-4">
            {actions.map((action) => (
              <a
                href={action.href}
                class={
                  action.variant === "secondary"
                    ? "btn-clipped inline-flex items-center gap-2 px-8 py-3 text-xs font-bold uppercase tracking-wider border-2 border-primary-light text-primary-light hover:bg-primary-light hover:text-white transition-all duration-300"
                    : "btn-clipped inline-flex items-center gap-2 px-8 py-3 text-xs font-bold uppercase tracking-wider bg-primary-light text-white hover:bg-primary-lighter transition-all duration-300"
                }
              >
                {action.text}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

