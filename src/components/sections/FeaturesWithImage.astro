---
import { Icon } from "astro-icon/components";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  image?: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  cards: Card[];
  ctaText?: string;
  ctaLink?: string;
  isCarousel?: boolean; // Enable carousel mode
  itemsPerSlide?: number; // Number of items visible per slide (default: 2)
  carouselAutoplay?: boolean; // Auto-advance slides
  carouselAutoplayDelay?: number; // Delay in ms (default: 5000)
}

const {
  title,
  eyebrow,
  description,
  cards = [],
  ctaText,
  ctaLink,
  isCarousel: isCarouselProp,
  itemsPerSlide = 2,
  carouselAutoplay = false,
  carouselAutoplayDelay = 5000,
} = Astro.props;

// Automatically enable carousel if more than 4 cards, otherwise use prop value
const isCarousel = cards.length > 4 ? true : (isCarouselProp || false);

// Show all cards if carousel, otherwise limit to max 4
const displayCards = isCarousel ? cards : cards.slice(0, 4);
const cardCount = displayCards.length;

// Adaptive grid classes based on card count
const getGridClasses = () => {
  switch (cardCount) {
    case 1:
      return "grid grid-cols-1 max-w-md mx-auto";
    case 2:
      return "grid grid-cols-1 sm:grid-cols-2 max-w-3xl mx-auto";
    case 3:
      return "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto";
    case 4:
    default:
      return "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4";
  }
};

---

<section class="py-12 sm:py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      (eyebrow || title || description) && (
        <div class="text-center mb-8 sm:mb-12" data-animate="fade-up">
          {eyebrow && (
            <div class="flex items-center justify-center gap-2 mb-2">
              <div class="h-px w-12 bg-primary" />
              <p class="text-xs sm:text-sm font-bold uppercase tracking-wider text-primary">
                {eyebrow}
              </p>
            </div>
          )}
          {title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4">
              {title}
            </h2>
          )}
          {description && (
            <p class="text-base sm:text-lg md:text-xl text-gray-600 max-w-3xl mx-auto">
              {description}
            </p>
          )}
        </div>
      )
    }

    {
      isCarousel ? (
        <div
          class="relative"
          data-feature-carousel-root
          data-items-per-slide={String(itemsPerSlide)}
          data-autoplay={String(carouselAutoplay)}
          data-autoplay-delay={String(carouselAutoplayDelay)}
        >
          {/* Carousel Container */}
          <div class="overflow-hidden">
            <div
              class="flex transition-all duration-500 ease-in-out"
              data-carousel-track
            >
              {displayCards.map((card) => (
                <div
                  class="flex-shrink-0 px-3"
                  style={`width: ${100 / itemsPerSlide}%`}
                >
                  <div class="bg-white overflow-hidden transition-all duration-300 h-full border-l-4 border-primary-light hover:shadow-lg group">
                    {card.image && (
                      <div class="relative h-48 overflow-hidden">
                        <img
                          src={card.image}
                          alt={card.title || "Card image"}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="p-6">
                      {card.icon && (
                        <div class="w-10 h-10 bg-primary flex items-center justify-center mb-4">
                          <Icon name={card.icon} class="w-5 h-5 text-white" />
                        </div>
                      )}
                      {card.title && (
                        <h3
                          class="text-lg font-bold text-primary-dark mb-2"
                          set:html={card.title}
                        />
                      )}
                      {card.description && (
                        <p
                          class="text-sm text-gray-600 leading-relaxed"
                          set:html={card.description}
                        />
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Navigation Buttons */}
          <button
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-primary text-white p-3 hover:bg-primary-dark transition z-10"
            data-carousel-prev
            aria-label="Previous slide"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              />
            </svg>
          </button>
          <button
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-primary text-white p-3 hover:bg-primary-dark transition z-10"
            data-carousel-next
            aria-label="Next slide"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </button>

          {/* Dots Indicator */}
          <div class="flex justify-center gap-2 mt-6">
            {Array.from({
              length: Math.ceil(displayCards.length / itemsPerSlide),
            }).map((_, index) => (
              <button
                class="w-3 h-3 bg-gray-300 hover:bg-primary transition"
                data-carousel-dot={index}
                aria-label={`Go to slide ${index + 1}`}
              />
            ))}
          </div>
        </div>
      ) : (
        <div class={`${getGridClasses()} gap-6 lg:gap-8`} data-animate-stagger>
          {displayCards.map((card) => (
            <div class="bg-white overflow-hidden border-l-4 border-primary-light hover:shadow-lg transition-all duration-300 group">
              {card.image && (
                <div class="relative h-48 overflow-hidden">
                  <img
                    src={card.image}
                    alt={card.title || "Card image"}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                {card.icon && (
                  <div class="w-10 h-10 bg-primary flex items-center justify-center mb-4">
                    <Icon name={card.icon} class="w-5 h-5 text-white" />
                  </div>
                )}
                {card.title && (
                  <h3
                    class="text-lg font-bold text-primary-dark mb-2"
                    set:html={card.title}
                  />
                )}
                {card.description && (
                  <p
                    class="text-sm text-gray-600 leading-relaxed"
                    set:html={card.description}
                  />
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }

    {
      ctaText && ctaLink && (
        <div class="text-center mt-8 sm:mt-12">
          <a
            href={ctaLink}
            class="inline-block px-6 py-3 sm:px-8 sm:py-4 bg-primary text-white font-medium hover:bg-primary-dark transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105 text-sm sm:text-base"
          >
            {ctaText}
          </a>
        </div>
      )
    }
  </div>
</section>

<script>
  function initFeatureCarousels() {
    const carousels = document.querySelectorAll("[data-feature-carousel-root]");
    if (!carousels.length) return;

    carousels.forEach((carousel) => {
      const el = carousel as HTMLElement;
      if (el.dataset.carouselInitialized === "true") return;

      const track = el.querySelector("[data-carousel-track]") as HTMLElement | null;
      const prevBtn = el.querySelector("[data-carousel-prev]") as HTMLButtonElement | null;
      const nextBtn = el.querySelector("[data-carousel-next]") as HTMLButtonElement | null;
      const dots = el.querySelectorAll("[data-carousel-dot]");
      const itemsPerSlide = Number(el.dataset.itemsPerSlide || "2");
      const autoplay = el.dataset.autoplay === "true";
      const autoplayDelay = Number(el.dataset.autoplayDelay || "5000");
      const totalCards = track?.children.length || 0;

      if (!track || !prevBtn || !nextBtn || !dots.length || !totalCards) return;

      el.dataset.carouselInitialized = "true";

      let currentIndex = 0;
      const totalSlides = Math.ceil(totalCards / itemsPerSlide);
      let autoplayInterval: ReturnType<typeof setInterval>;

      function updateCarousel() {
        const offset = -(currentIndex * 100);
        track!.style.opacity = "0";
        setTimeout(() => {
          track!.style.transform = `translateX(${offset}%)`;
          track!.style.opacity = "1";
        }, 150);

        dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.add("bg-primary");
            dot.classList.remove("bg-gray-300");
          } else {
            dot.classList.remove("bg-primary");
            dot.classList.add("bg-gray-300");
          }
        });

        prevBtn!.disabled = false;
        nextBtn!.disabled = false;
        prevBtn!.style.opacity = "1";
        nextBtn!.style.opacity = "1";
      }

      function goToSlide(index: number) {
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));
        updateCarousel();
        resetAutoplay();
      }

      function nextSlide() {
        goToSlide(currentIndex < totalSlides - 1 ? currentIndex + 1 : 0);
      }

      function prevSlide() {
        goToSlide(currentIndex > 0 ? currentIndex - 1 : totalSlides - 1);
      }

      function resetAutoplay() {
        if (autoplay) {
          clearInterval(autoplayInterval);
          autoplayInterval = setInterval(nextSlide, autoplayDelay);
        }
      }

      prevBtn.addEventListener("click", prevSlide);
      nextBtn.addEventListener("click", nextSlide);
      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => goToSlide(index));
      });

      el.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") prevSlide();
        if (e.key === "ArrowRight") nextSlide();
      });

      let touchStartX = 0;
      el.addEventListener("touchstart", (e) => {
        touchStartX = e.changedTouches[0].screenX;
      });
      el.addEventListener("touchend", (e) => {
        const diff = touchStartX - e.changedTouches[0].screenX;
        if (diff > 50) nextSlide();
        if (diff < -50) prevSlide();
      });

      updateCarousel();
      if (autoplay) {
        autoplayInterval = setInterval(nextSlide, autoplayDelay);
        el.addEventListener("mouseenter", () => clearInterval(autoplayInterval));
        el.addEventListener("mouseleave", resetAutoplay);
      }
    });
  }

  document.addEventListener("astro:page-load", initFeatureCarousels);
</script>
