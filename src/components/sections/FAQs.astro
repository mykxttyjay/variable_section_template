---
interface FAQ {
  question?: string;
  answer?: string;
}

interface Props {
  title?: string;
  faqs: FAQ[];
}

const { title, faqs = [] } = Astro.props;

const bgStyle = "background-color: #f9f9f7; background-image: radial-gradient(ellipse at 100% 0%, rgba(0,107,114,0.10) 0%, transparent 65%), radial-gradient(ellipse at 0% 100%, rgba(0,173,181,0.09) 0%, transparent 65%), radial-gradient(ellipse at 50% 50%, rgba(0,107,114,0.05) 0%, transparent 70%);";

// Generate FAQPage schema for SEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer?.replace(/<[^>]*>/g, ""), // Strip HTML for schema
    },
  })),
};
---

<!-- FAQPage Structured Data -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(faqSchema)}
/>

<section class="py-16 md:py-24 relative overflow-hidden" style={bgStyle}>
  <!-- Decorative Glow Blob -->
  <div class="glow-orb glow-orb-mint w-[400px] h-[400px] -bottom-20 -right-20 opacity-10"></div>
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4">
    {
      title && (
        <div class="mb-12" data-animate="fade-up">
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">
            {title}
          </h2>
          <div class="h-1.5 w-20 bg-gradient-to-r from-primary-light to-secondary rounded-full" />
        </div>
      )
    }

    <div class="space-y-3" data-animate-stagger>
      {
        faqs.map((faq) => (
          <details class="group bg-white border border-slate-100 shadow-[0_4px_25px_-5px_rgba(15,23,42,0.03)] hover:shadow-[0_8px_30px_-5px_rgba(0,107,114,0.08)] hover:border-primary-light/35 transition-all duration-300 overflow-hidden rounded-lg">
            <summary
              class="flex justify-between items-center cursor-pointer p-6 hover:bg-slate-50/50 transition-colors duration-300"
              aria-label={`Toggle answer for: ${faq.question}`}
            >
              <h3 class="text-base md:text-lg font-semibold text-primary-dark pr-8 group-hover:text-primary transition-colors duration-200">
                {faq.question}
              </h3>
              <div
                class="flex-shrink-0 w-8 h-8 bg-slate-100 text-slate-700 flex items-center justify-center transition-all duration-300 group-open:bg-primary-light group-open:text-white group-open:rotate-45 rounded-lg"
                aria-hidden="true"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 4v16m8-8H4"
                  />
                </svg>
              </div>
            </summary>
            <div class="px-6 pb-6 text-slate-600 bg-slate-50/30 border-t border-slate-50">
              <p set:html={faq.answer} class="leading-relaxed text-sm md:text-base pt-4" />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
