---
import { Icon } from "astro-icon/components";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  cards: Card[];
}

const { title, description, ctaText, ctaLink, cards = [] } = Astro.props;
---

<section class="py-16 md:py-24 relative overflow-hidden" style="background-color: #f9f9f7; background-image: radial-gradient(ellipse at 0% 0%, rgba(0,107,114,0.08) 0%, transparent 50%), radial-gradient(ellipse at 100% 100%, rgba(0,173,181,0.07) 0%, transparent 50%), radial-gradient(ellipse at 80% 10%, rgba(0,107,114,0.05) 0%, transparent 40%);">
  <!-- Decorative Glow Blobs -->
  <div class="glow-orb glow-orb-green w-[600px] h-[600px] -top-[10%] -left-[10%] opacity-15"></div>
  <div class="glow-orb glow-orb-mint w-[500px] h-[500px] -bottom-[10%] -right-[10%] opacity-15"></div>

  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4 relative z-10">
    {
      (title || description) && (
        <div class="mb-12" data-animate="fade-up">
          {title && (
            <div class="mb-4">
              <h2 class="text-3xl md:text-4xl font-bold mb-2 text-primary-dark">{title}</h2>
              <div class="h-1.5 w-24 bg-gradient-to-r from-primary-light to-secondary rounded-full mb-6" />
            </div>
          )}
          {description && (
            <p
              class="text-lg text-gray-700 [&_strong]:text-primary-dark [&_strong]:font-semibold [&_a]:text-primary-light [&_a]:underline [&_a]:font-semibold [&_a]:hover:text-primary"
              set:html={description}
            />
          )}
        </div>
      )
    }

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
      data-animate-stagger
    >
      {
        cards.map((card) => {
          const CardWrapper = card.link ? "a" : "div";
          const wrapperProps = card.link ? { href: card.link } : {};

          return (
            <CardWrapper
              {...wrapperProps}
              class={`group relative p-8 bg-white border border-gray-100 hover:shadow-lg hover:border-primary-light/30 transition-all duration-300 ${card.link ? "cursor-pointer" : ""}`}
              style="clip-path: polygon(0% 0%, calc(100% - 20px) 0%, 100% 20px, 100% 100%, 0% 100%);"
            >
              {/* Fold triangle in top-right corner */}
              <div class="absolute top-0 right-0 w-0 h-0 pointer-events-none"
                style="border-style: solid; border-width: 0 20px 20px 0; border-color: transparent #e5e7eb transparent transparent;">
              </div>
              <div class="absolute top-0 right-0 w-0 h-0 pointer-events-none group-hover:border-r-primary-light/30 transition-colors duration-300"
                style="border-style: solid; border-width: 0 20px 20px 0; border-color: transparent #f9f9f7 transparent transparent;">
              </div>

              {card.icon && (
                <div class="w-12 h-12 bg-primary-light text-white flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                  <Icon name={card.icon} class="w-6 h-6" />
                </div>
              )}
              <h3 class="font-bold mb-3 text-primary-dark group-hover:text-primary-light transition-colors duration-300" style="font-size: 16px;">
                {card.title}
              </h3>
              <p class="text-gray-600 leading-relaxed" style="font-size: 15px;" set:html={card.description} />
            </CardWrapper>
          );
        })
      }
    </div>

    {ctaText && ctaLink && (
      <div class="mt-10 flex justify-center">
        <a
          href={ctaLink}
          class="btn-clipped inline-flex items-center gap-2 px-8 py-3 bg-primary-light text-white text-xs font-bold uppercase tracking-wider transition-all duration-300 hover:bg-primary-lighter"
        >
          {ctaText}
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
