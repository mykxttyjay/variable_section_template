---
import { Icon } from "astro-icon/components";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  cards: Card[];
}

const { title, description, ctaText, ctaLink, cards = [] } = Astro.props;
---

<section class="py-16 md:py-24 bg-primary-dark text-white relative overflow-hidden">
  <!-- Decorative Glow Blobs -->
  <div class="glow-orb glow-orb-green w-[600px] h-[600px] -top-[10%] -left-[10%] opacity-15"></div>
  <div class="glow-orb glow-orb-mint w-[500px] h-[500px] -bottom-[10%] -right-[10%] opacity-15"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {
      (title || description) && (
        <div class="mb-12" data-animate="fade-up">
          {title && (
            <div class="mb-4">
              <h2 class="text-3xl md:text-4xl font-bold mb-2">{title}</h2>
              <div class="h-1.5 w-24 bg-gradient-to-r from-primary-light to-secondary rounded-full" />
            </div>
          )}
          {description && (
            <p
              class="text-lg text-gray-200 max-w-2xl [&_strong]:text-white [&_strong]:font-semibold"
              set:html={description}
            />
          )}
          {ctaText && ctaLink && (
            <div class="mt-6">
              <a
                href={ctaLink}
                class="btn-clipped btn-premium inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-primary-light to-secondary text-white text-xs font-bold uppercase tracking-wider transition-all duration-300"
              >
                {ctaText}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            </div>
          )}
        </div>
      )
    }

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
      data-animate-stagger
    >
      {
        cards.map((card) => {
          const CardWrapper = card.link ? "a" : "div";
          const wrapperProps = card.link ? { href: card.link } : {};

          return (
            <CardWrapper
              {...wrapperProps}
              class={`group p-8 glass-panel-dark rounded-2xl border border-white/5 hover:border-white/20 transition-all duration-300 hover-lift-deluxe ${card.link ? "cursor-pointer" : ""}`}
            >
              {card.icon && (
                <div class="w-12 h-12 rounded-xl bg-gradient-to-tr from-primary-light to-secondary text-white flex items-center justify-center mb-6 shadow-md group-hover:scale-110 transition-transform duration-300">
                  <Icon name={card.icon} class="w-6 h-6" />
                </div>
              )}
              <h3 class="text-lg font-bold mb-2 text-white group-hover:text-gray-300 transition-colors">
                {card.title}
              </h3>
              <p class="text-sm text-gray-300" set:html={card.description} />
            </CardWrapper>
          );
        })
      }
    </div>
  </div>
</section>
