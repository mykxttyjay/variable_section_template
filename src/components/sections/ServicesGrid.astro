---
import { Icon } from "astro-icon/components";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  cards: Card[];
}

const { title, description, ctaText, ctaLink, cards = [] } = Astro.props;
---

<section
  class="py-16 md:py-24 bg-primary-dark text-white relative overflow-hidden"
>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {
      (title || description) && (
        <div class="mb-12" data-animate="fade-up">
          {title && (
            <div class="mb-4">
              <h2 class="text-3xl md:text-4xl font-bold mb-2">{title}</h2>
              <div class="h-1 w-32 bg-primary-light" />
            </div>
          )}
          {description && (
            <p
              class="text-lg text-gray-200 max-w-2xl [&_strong]:text-white [&_strong]:font-semibold"
              set:html={description}
            />
          )}
          {ctaText && ctaLink && (
            <div class="mt-6">
              <a
                href={ctaLink}
                class="inline-block px-8 py-3 bg-primary-light text-white font-semibold hover:bg-primary-lighter transition shadow-lg shadow-primary-light/30"
              >
                {ctaText}
              </a>
            </div>
          )}
        </div>
      )
    }

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
      data-animate-stagger
    >
      {
        cards.map((card) => {
          const CardWrapper = card.link ? "a" : "div";
          const wrapperProps = card.link ? { href: card.link } : {};

          return (
            <CardWrapper
              {...wrapperProps}
              class={`group p-6 bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/20 hover:border-white/40 transition-all duration-300 ${card.link ? "cursor-pointer hover:shadow-lg" : ""}`}
            >
              {card.icon && (
                <div class="w-12 h-12 bg-primary-light text-white flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                  <Icon name={card.icon} class="w-6 h-6" />
                </div>
              )}
              <h3 class="text-lg font-bold mb-2 text-white group-hover:text-gray-300 transition-colors">
                {card.title}
              </h3>
              <p class="text-sm text-gray-300" set:html={card.description} />
            </CardWrapper>
          );
        })
      }
    </div>
  </div>
</section>
