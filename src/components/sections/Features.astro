---
import { Icon } from "astro-icon/components";

interface Feature {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features = [] } = Astro.props;
---

<section class="bg-white">
  <div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    {
      (title || subtitle) && (
        <div class="mb-16" data-animate="fade-up">
          {title && (
            <div class="flex items-center gap-3 mb-4">
              <div class="h-1 w-20 bg-gradient-to-r from-primary to-accent" />
              <h2 class="text-3xl md:text-4xl font-bold text-primary-dark">
                {title}
              </h2>
            </div>
          )}
          {subtitle && <p class="text-xl text-gray-600 ml-24">{subtitle}</p>}
        </div>
      )
    }

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      data-animate-stagger
    >
      {
        features.map((feature) => {
          const CardWrapper = feature.link ? "a" : "div";
          const wrapperProps = feature.link ? { href: feature.link } : {};

          return (
            <CardWrapper
              {...wrapperProps}
              class="group p-8 bg-gray-50 hover:bg-white transition-all duration-300 block border-2 border-gray-300 hover:border-primary-light shadow-lg hover:shadow-xl hover:-translate-y-1 rounded-lg overflow-hidden relative"
            >
              <div class="flex items-start gap-5 relative z-10">
                {feature.icon && (
                  <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-primary-light to-primary text-white flex items-center justify-center group-hover:scale-125 transition-transform duration-300 rounded-lg shadow-lg">
                    <Icon name={feature.icon} class="w-8 h-8" />
                  </div>
                )}
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-primary-dark mb-2 group-hover:text-primary transition-colors duration-200">
                    {feature.title}
                  </h3>
                  <p
                    class="text-gray-600 text-sm leading-relaxed group-hover:text-gray-700 transition-colors duration-200"
                    set:html={feature.description}
                  />
                </div>
              </div>
            </CardWrapper>
          );
        })
      }
    </div>
  </div>
</section>
