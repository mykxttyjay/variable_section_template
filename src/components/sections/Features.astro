---
import { Icon } from "astro-icon/components";

interface Feature {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features = [] } = Astro.props;
---

<section class="bg-white">
  <div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    {
      (title || subtitle) && (
        <div class="mb-16" data-animate="fade-up">
          {title && (
            <div class="flex items-center gap-3 mb-4">
              <div class="h-1 w-20 bg-gradient-to-r from-primary to-accent" />
              <h2 class="text-3xl md:text-4xl font-bold text-primary-dark">
                {title}
              </h2>
            </div>
          )}
          {subtitle && <p class="text-xl text-gray-600 ml-24">{subtitle}</p>}
        </div>
      )
    }

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      data-animate-stagger
    >
      {
        features.map((feature) => {
          const CardWrapper = feature.link ? "a" : "div";
          const wrapperProps = feature.link ? { href: feature.link } : {};

          return (
            <CardWrapper
              {...wrapperProps}
              class="group p-6 bg-gray-50 hover:bg-white transition-all duration-300 block"
            >
              <div class="flex items-start gap-4">
                {feature.icon && (
                  <div class="flex-shrink-0 w-12 h-12 bg-primary text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                    <Icon name={feature.icon} class="w-6 h-6" />
                  </div>
                )}
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-primary-dark mb-2 group-hover:text-primary transition-colors">
                    {feature.title}
                  </h3>
                  <p
                    class="text-gray-600 text-sm leading-relaxed"
                    set:html={feature.description}
                  />
                </div>
              </div>
            </CardWrapper>
          );
        })
      }
    </div>
  </div>
</section>
