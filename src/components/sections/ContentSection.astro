---
import { Icon } from 'astro-icon/components';

export interface Props {
  sectionData: {
    section: string;
    title: string;
    description: string;
    image?: string;
    ctaText?: string;
    ctaLink?: string;
    features?: Array<{
      title: string;
      description: string;
      image?: string;
      icon?: string;
    }>;
  };
  variant?: 'hero' | 'overview' | 'features' | 'value-proposition' | 'default';
  className?: string;
}

const { sectionData, variant = 'default', className = '' } = Astro.props;
const { title, description, image, ctaText, ctaLink, features } = sectionData;

// Determine section styling based on variant
const getSectionClasses = (variant: string) => {
  const baseClasses = 'py-12 md:py-16 lg:py-20';
  
  switch (variant) {
    case 'hero':
      return `${baseClasses} bg-gradient-to-br from-neutral to-white`;
    case 'overview':
      return `${baseClasses} bg-gray-50`;
    case 'value-proposition':
      return `${baseClasses} bg-neutral`;
    case 'features':
      return `${baseClasses} bg-white`;
    default:
      return `${baseClasses} bg-white`;
  }
};

const getContainerClasses = () => {
  return 'max-w-7xl mx-auto px-2 sm:px-3 lg:px-4';
};

const getLayoutClasses = (variant: string, hasImage: boolean) => {
  if (!hasImage && variant !== 'features') {
    return 'text-center max-w-4xl mx-auto';
  }
  
  if (variant === 'features') {
    return 'w-full';
  }
  
  return 'grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center';
};
---

<section class={`${getSectionClasses(variant)} ${className}`}>
  <div class={getContainerClasses()}>
    {variant === 'features' ? (
      <div class="w-full">
        <!-- Features Header -->
        <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16" data-animate="fade-up">
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4 lg:mb-6">
            {title}
          </h2>
          <p class="text-base sm:text-lg md:text-xl text-gray-600">
            {description}
          </p>
        </div>

        <!-- Features Grid -->
        {features && features.length > 0 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8" data-animate-stagger>
            {features.map((feature) => (
              <div class="p-4 lg:p-6 bg-white border border-gray-200 shadow-md hover:shadow-xl transition-all duration-200 rounded-lg group">
                {feature.image && (
                  <div class="mb-4">
                    <img
                      src={feature.image}
                      alt={feature.title}
                      class="w-full h-40 sm:h-48 object-cover"
                      loading="lazy"
                      width="300"
                      height="200"
                    />
                  </div>
                )}
                {feature.icon && !feature.image && (
                  <div class="w-14 h-14 sm:w-16 sm:h-16 bg-gradient-to-br from-primary-light to-primary text-white flex items-center justify-center mb-4 rounded-lg shadow-lg group-hover:scale-110 transition-transform">
                    <Icon name={feature.icon} class="w-7 h-7 sm:w-8 sm:h-8" />
                  </div>
                )}
                <h3 class="text-lg sm:text-xl font-semibold text-primary-dark mb-2 group-hover:text-primary transition-colors">
                  {feature.title}
                </h3>
                <p class="text-sm sm:text-base text-gray-600 group-hover:text-gray-700 transition-colors">
                  {feature.description}
                </p>
              </div>
            ))}
          </div>
        )}

        <!-- Features CTA -->
        {ctaText && ctaLink && (
          <div class="text-center mt-8 lg:mt-12">
            <a
              href={ctaLink}
              class="btn-clipped inline-flex items-center gap-2 justify-center px-6 py-3 md:px-8 md:py-4 bg-primary text-white text-xs font-bold uppercase tracking-wider hover:bg-primary-dark focus:ring-4 focus:ring-primary-lighter transition-all duration-200"
              aria-label={`${ctaText} - ${title}`}
            >
              {ctaText}
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>
          </div>
        )}
      </div>
    ) : (
      <div class={getLayoutClasses(variant, !!image)}>
        <!-- Content Column -->
        <div class={image ? 'lg:order-1' : 'w-full'} data-animate={image ? 'fade-right' : 'fade-up'}>
          {variant === 'hero' ? (
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-primary-dark mb-4 lg:mb-6 leading-tight">
              {title}
            </h1>
          ) : (
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-primary-dark mb-4 lg:mb-6">
              {title}
            </h2>
          )}
          
          <p class={`text-gray-600 mb-6 lg:mb-8 ${
            variant === 'hero' 
              ? 'text-lg sm:text-xl md:text-2xl' 
              : 'text-base sm:text-lg md:text-xl'
          }`}>
            {description}
          </p>
          
          {ctaText && ctaLink && (
            <div class={image ? 'text-left' : 'text-center'}>
              <a 
                href={ctaLink}
                class="btn-clipped inline-flex items-center gap-2 justify-center px-6 py-3 md:px-8 md:py-4 bg-primary text-white text-xs font-bold uppercase tracking-wider hover:bg-primary-dark focus:ring-4 focus:ring-primary-lighter transition-all duration-200"
                aria-label={`${ctaText} - ${title}`}
              >
                {ctaText}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            </div>
          )}
        </div>
        
        <!-- Image Column -->
        {image && (
          <div class={`lg:order-2 w-full ${variant === 'overview' ? 'lg:order-first' : ''}`} data-animate="fade-left">
            <div class="relative overflow-hidden shadow-lg">
              <img 
                src={image}
                alt={`${title} illustration`}
                class="w-full h-auto object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
                width="600"
                height="400"
              />
              <!-- Overlay for better visual effect -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300"></div>
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<style>
  /* Responsive typography scaling */
  @media (max-width: 640px) {
    h1, h2 {
      line-height: 1.2;
    }
  }
  
  /* Smooth transitions for interactive elements */
  a, img {
    transition: all 0.3s ease;
  }
  
  /* Focus styles for accessibility */
  a:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  
  /* Optimize for print media */
  @media print {
    section {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }
  
  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .text-gray-600 {
      color: #374151;
    }
  }
  
  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
