---
interface Props {
  text?: string;
}

const { text = "Free Consultation" } = Astro.props;
---

<button
  id="floating-cta-button"
  type="button"
  class="fixed bottom-6 right-6 z-40 bg-E8F08D text-[#102b32] font-bold tracking-wider transition-all duration-300 flex items-center gap-3 group shadow-2xl border-0 rounded-xl"
  style="padding: 8px 12px; font-size: 15px;"
  aria-label="Open free consultation popup"
>
  <svg
    class="w-5 h-5 flex-shrink-0"
    fill="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
    ></path>
  </svg>
  <span class="hidden sm:inline font-bold">{text}</span>
  <span class="sm:hidden font-bold">Consult</span>
</button>

<script>
  function bindFloatingCTA() {
    const btn = document.getElementById("floating-cta-button");
    if (!btn || btn.dataset.bound === "true") return;
    btn.dataset.bound = "true";
    btn.addEventListener("click", () => {
      window.dispatchEvent(new Event("show-popup-modal"));
    });
  }

  document.addEventListener("astro:page-load", bindFloatingCTA);
</script>

<style>
  #floating-cta-button {
    position: relative;
    animation: float-in 0.5s ease-out, floating 3s ease-in-out 0.3s infinite, pulse-glow 2.5s ease-in-out 0.5s infinite;
  }

  @keyframes float-in {
    from {
      opacity: 0;
      transform: translateY(100px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Enhanced floating animation - smooth up and down motion */
  @keyframes floating {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  /* Enhanced pulse glow effect */
  @keyframes pulse-glow {
    0%,
    100% {
      box-shadow: 0 10px 30px rgba(232, 240, 141, 0.4), 0 0 20px rgba(232, 240, 141, 0.2);
    }
    50% {
      box-shadow: 0 20px 50px rgba(232, 240, 141, 0.6), 0 0 40px rgba(232, 240, 141, 0.4), inset 0 0 20px rgba(232, 240, 141, 0.1);
    }
  }

  /* Hover state with swipe animation from right to left */
  #floating-cta-button::before {
    content: "";
    position: absolute;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100%;
    background: #102b32;
    border-radius: 12px;
    transition: right 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
  }

  #floating-cta-button:hover {
    animation: float-in 0s, hover-lift 0.3s ease-out forwards, pulse-glow-hover 0.6s ease-in-out infinite !important;
  }

  #floating-cta-button:hover::before {
    right: 0;
  }

  #floating-cta-button:hover {
    color: #E8F08D;
  }

  @keyframes hover-lift {
    from {
      transform: translateY(0px);
    }
    to {
      transform: translateY(-20px) scale(1.08);
    }
  }

  /* Enhanced glow on hover */
  @keyframes pulse-glow-hover {
    0%,
    100% {
      box-shadow: 0 25px 60px rgba(16, 43, 50, 0.6), 0 0 50px rgba(16, 43, 50, 0.4);
    }
    50% {
      box-shadow: 0 30px 80px rgba(16, 43, 50, 0.8), 0 0 70px rgba(16, 43, 50, 0.6), inset 0 0 30px rgba(16, 43, 50, 0.2);
    }
  }

  /* Accessibility: respect motion preferences */
  @media (prefers-reduced-motion: reduce) {
    #floating-cta-button {
      animation: float-in 0.5s ease-out !important;
    }

    #floating-cta-button:hover {
      animation: float-in 0s !important;
    }
  }
</style>
