---
interface Props {
  text?: string;
}

const { text = "Free Consultation" } = Astro.props;
---

<button
  id="floating-cta-button"
  type="button"
  class="fixed bottom-6 right-6 z-40 px-8 py-4 bg-gradient-to-r from-[#dff39e] to-[#e8f5a8] text-[#102b32] font-bold uppercase tracking-wider transition-all duration-300 flex items-center gap-3 group shadow-lg rounded-lg border-0 hover:shadow-xl hover:scale-105"
  style="font-size: 15px;"
  aria-label="Open free consultation popup"
>
  <svg
    class="w-6 h-6 group-hover:scale-110 transition-transform duration-300 flex-shrink-0"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
    ></path>
  </svg>
  <span class="hidden sm:inline font-bold">{text}</span>
  <span class="sm:hidden font-bold">Consult</span>
</button>

<script>
  function bindFloatingCTA() {
    const btn = document.getElementById("floating-cta-button");
    if (!btn || btn.dataset.bound === "true") return;
    btn.dataset.bound = "true";
    btn.addEventListener("click", () => {
      window.dispatchEvent(new Event("show-popup-modal"));
    });
  }

  document.addEventListener("astro:page-load", bindFloatingCTA);
</script>

<style>
  #floating-cta-button {
    animation: float-in 0.5s ease-out, floating 3s ease-in-out 0.3s infinite, pulse-glow 2.5s ease-in-out 0.5s infinite;
  }

  @keyframes float-in {
    from {
      opacity: 0;
      transform: translateY(100px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Enhanced floating animation - smooth up and down motion */
  @keyframes floating {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  /* Enhanced pulse glow effect */
  @keyframes pulse-glow {
    0%,
    100% {
      box-shadow: 0 10px 30px rgba(223, 243, 158, 0.3), 0 0 20px rgba(223, 243, 158, 0.2);
    }
    50% {
      box-shadow: 0 20px 50px rgba(223, 243, 158, 0.5), 0 0 40px rgba(223, 243, 158, 0.4);
    }
  }

  /* Hover state with dramatic lift and glow */
  #floating-cta-button:hover {
    animation: float-in 0s, hover-lift 0.3s ease-out forwards, pulse-glow-hover 0.6s ease-in-out infinite !important;
  }

  @keyframes hover-lift {
    from {
      transform: translateY(0px);
    }
    to {
      transform: translateY(-10px) scale(1.08);
    }
  }

  /* Enhanced glow on hover */
  @keyframes pulse-glow-hover {
    0%,
    100% {
      box-shadow: 0 15px 50px rgba(223, 243, 158, 0.6), 0 0 40px rgba(223, 243, 158, 0.4);
    }
    50% {
      box-shadow: 0 20px 70px rgba(223, 243, 158, 0.8), 0 0 60px rgba(223, 243, 158, 0.6);
    }
  }

  /* Accessibility: respect motion preferences */
  @media (prefers-reduced-motion: reduce) {
    #floating-cta-button {
      animation: float-in 0.5s ease-out !important;
    }

    #floating-cta-button:hover {
      animation: float-in 0s !important;
    }
  }
</style>
