---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "dark";
  size?: "default" | "sm" | "lg";
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  size = "default",
  class: className,
  ...rest
} = Astro.props;

const variants = {
  primary:
    "bg-primary-light text-white hover:bg-primary-lighter shadow-lg shadow-primary-light/30",
  secondary:
    "bg-white text-primary-dark border-2 border-primary-light hover:bg-primary-light hover:text-white",
  dark: "bg-primary text-white hover:bg-primary-dark",
};

const sizes = {
  sm: "px-6 py-2.5 text-sm",
  default: "px-8 py-3 text-base",
  lg: "px-8 py-4 text-base",
};

const classes = [
  "inline-flex items-center justify-center gap-2 font-semibold transition-all duration-300 whitespace-nowrap",
  variants[variant],
  sizes[size],
  className,
]
  .filter(Boolean)
  .join(" ");
---

<a href={href} class={classes} {...rest}>
  <slot />
</a>
