---
import { Icon } from "astro-icon/components";
import { navItems, ctaButton } from "~/config/navigation";
import { siteConfig } from "~/config/site";

interface NavLink {
  text: string;
  href?: string;
  description?: string;
  icon?: string;
  thumbnail?: string;
  links?: NavLink[];
}

// Get current page path to exclude from featured
const currentPath = Astro.url.pathname;

// Get featured items from Solutions megamenu
const solutionsMegamenu = navItems.find((item: any) => item.type === 'megamenu' && item.title === 'Solutions') as any;
const featuredItems = solutionsMegamenu?.featured || [];

// Filter out current page and pick random featured solution
const availableFeatured = featuredItems.filter((item: any) => {
  return !currentPath.includes(item.href);
});

// Pick random featured item
const featuredSolution = availableFeatured.length > 0
  ? availableFeatured[Math.floor(Math.random() * availableFeatured.length)]
  : featuredItems[0]; // Fallback to first if somehow empty

const featuredHref = featuredSolution?.href || '#';

// Convert navItems to the format expected by the template
const links: NavLink[] = navItems.map((item: any) => {
  if (item.type === 'link') {
    return {
      text: item.title,
      href: item.href,
    };
  }
  
  if (item.type === 'dropdown') {
    // For Indoor Billboards dropdown, use the items from JSON
    if (item.title === "Indoor Billboards") {
      return {
        text: item.title,
        links: item.items.map((subItem: any) => ({
          text: subItem.title,
          description: subItem.description,
          icon: subItem.icon,
          thumbnail: subItem.thumbnail,
          href: subItem.href,
        })),
      };
    }
    
    return {
      text: item.title,
      links: item.items.map((subItem: any) => ({
        text: subItem.title,
        description: subItem.description,
        icon: subItem.icon,
        thumbnail: subItem.thumbnail,
        href: subItem.href,
      })),
    };
  }
  
  if (item.type === 'megamenu') {
    // For Solutions megamenu, use the sections from JSON
    if (item.title === "Solutions") {
      return {
        text: item.title,
        href: item.href,
        links: item.sections.map((section: any) => ({
          text: section.label,
          links: section.items.map((subItem: any) => ({
            text: subItem.title,
            description: subItem.description,
            icon: subItem.icon,
            thumbnail: subItem.thumbnail,
            href: subItem.href,
          })),
        })),
      };
    }
  }
  
  return {
    text: item.title,
    href: item.href || '#',
  };
});

const actions = ctaButton ? [ctaButton] : [];
---

<header
  id="main-header"
  class="fixed top-0 z-40 flex-none mx-auto w-full bg-white/80 backdrop-blur-md border-b border-slate-100 transition-all duration-300 shadow-sm"
>
  <div class="max-w-7xl mx-auto px-2 sm:px-3 lg:px-4">
    <div
      class="flex justify-between items-center h-20"
      id="header-content"
    >
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center">
          <img
            id="header-logo"
            src="/images/logo/dealer-logo.svg"
            alt={siteConfig.logo.alt}
            class="h-12 w-auto transition-all duration-300"
            width="200"
            height="50"
            fetchpriority="high"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="desktop-nav">
        <nav
          class="flex items-center space-x-1 relative"
          aria-label="Main navigation"
        >
          {
            links.map((link, index) => (
              <div class="relative" data-dropdown={`dropdown-${index}`}>
                {link.links && link.links.length > 0 ? (
                  <>
                    {link.href ? (
                      <a
                        href={link.href}
                        class="dropdown-toggle px-4 py-2 font-semibold text-gray-700 hover:text-primary inline-flex items-center"
                        aria-label={`${link.text} menu`}
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        {link.text}
                        <svg
                          class="ml-1 h-4 w-4 transition-transform dropdown-arrow"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"
                          />
                        </svg>
                      </a>
                    ) : (
                      <button
                        class="dropdown-toggle px-4 py-2 font-semibold text-gray-700 hover:text-primary inline-flex items-center"
                        aria-label={`${link.text} menu`}
                        aria-haspopup="true"
                        aria-expanded="false"
                      >
                        {link.text}
                        <svg
                          class="ml-1 h-4 w-4 transition-transform dropdown-arrow"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"
                          />
                        </svg>
                      </button>
                    )}
                    {/* Mega Menu for Solutions */}
                    {link.text === "Solutions" ? (
                      <div class="dropdown-menu absolute left-1/2 -translate-x-1/2 mt-2 2xl:w-[1000px] xl:w-[550px] lg:w-[450px] w-[400px] max-w-[calc(100vw-2rem)] opacity-0 invisible pointer-events-none transition-all duration-200 z-50">
                        <div class="shadow-xl bg-white border border-gray-200 overflow-hidden">
                          <div class="grid 2xl:grid-cols-[1fr_280px] grid-cols-1 2xl:divide-x divide-gray-100">
                            {/* Categories Column - Full visibility, no scroll */}
                            <div class="relative">
                              <div
                                class="px-6 py-6"
                                id="solutions-scroll-container"
                              >
                                <div class="space-y-8">
                                  {link.links.map((sublink) => (
                                    <div>
                                      {sublink.href ? (
                                        <a
                                          href={sublink.href}
                                          class="inline-flex items-center gap-2 text-xs font-bold text-primary uppercase tracking-wider mb-4 hover:text-primary-dark"
                                        >
                                          {sublink.text}
                                          <svg
                                            class="w-3 h-3"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                          >
                                            <path
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="2"
                                              d="M9 5l7 7-7 7"
                                            />
                                          </svg>
                                        </a>
                                      ) : (
                                        <div class="inline-flex items-center gap-2 text-xs font-bold text-primary uppercase tracking-wider mb-4">
                                          {sublink.text}
                                          <svg
                                            class="w-3 h-3"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                          >
                                            <path
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="2"
                                              d="M9 5l7 7-7 7"
                                            />
                                          </svg>
                                        </div>
                                      )}
                                      {sublink.links &&
                                        sublink.links.length > 0 && (
                                          <div class="grid xl:grid-cols-2 grid-cols-1 gap-x-6 gap-y-1">
                                            {sublink.links.map((nestedLink) => (
                                              <a
                                                href={nestedLink.href}
                                                class="group/item flex items-start gap-3 px-3 py-3 hover:bg-neutral transition-all border-l-2 border-transparent hover:border-primary-light"
                                              >
                                                {nestedLink.icon && (
                                                  <div class="flex-shrink-0 w-8 h-8 bg-neutral flex items-center justify-center group-hover/item:bg-primary-light transition-colors">
                                                    <Icon
                                                      name={nestedLink.icon}
                                                      class="w-4 h-4 text-primary group-hover/item:text-white transition-colors"
                                                    />
                                                  </div>
                                                )}
                                                <div class="flex-1 min-w-0">
                                                  <div class="text-sm font-semibold text-gray-800 group-hover/item:text-primary transition-colors">
                                                    {nestedLink.text}
                                                  </div>
                                                  {nestedLink.description && (
                                                    <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">
                                                      {nestedLink.description}
                                                    </div>
                                                  )}
                                                </div>
                                                <svg class="w-3.5 h-3.5 text-gray-300 group-hover/item:text-primary-light transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                              </a>
                                            ))}
                                          </div>
                                        )}
                                    </div>
                                  ))}
                                </div>
                              </div>
                            </div>

                            {/* Featured Section - Random solution excluding current page */}
                            <div class="hidden 2xl:block bg-gradient-to-br from-neutral to-white p-8">
                              <div class="text-xs font-bold text-primary uppercase tracking-wider mb-4">
                                Featured
                              </div>
                              <a href={featuredHref} class="group block">
                                <div class="relative h-32 overflow-hidden mb-4 shadow-md">
                                  <img
                                    src={
                                      featuredSolution?.thumbnail ||
                                      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&h=300&fit=crop"
                                    }
                                    alt={featuredSolution?.title || 'Featured Solution'}
                                    class="w-full h-full object-cover transition-transform duration-300"
                                    loading="lazy"
                                    width="400"
                                    height="300"
                                  />
                                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                                  <div class="absolute bottom-3 left-3 right-3">
                                    <div class="text-white font-bold text-sm">
                                      {featuredSolution?.title}
                                    </div>
                                  </div>
                                </div>
                                <p class="text-xs text-gray-600 mb-4">
                                  {featuredSolution?.description}
                                </p>
                                <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary group-hover:gap-2 transition-all">
                                  Learn More
                                  <svg
                                    class="w-3 h-3"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M9 5l7 7-7 7"
                                    />
                                  </svg>
                                </span>
                              </a>
                            </div>
                          </div>
                        </div>
                      </div>
                    ) : (
                      /* Redesigned dropdown — sharp corners, accent left bar, clean layout */
                      <div class="dropdown-menu absolute left-0 lg:left-auto lg:right-0 mt-3 w-72 max-w-[calc(100vw-2rem)] opacity-0 invisible pointer-events-none transition-all duration-200 z-50">
                        <div class="bg-white border border-gray-200 shadow-xl overflow-hidden">                          <div class="py-3">
                            {link.href && (
                              <a
                                href={link.href}
                                class="flex items-center gap-2 px-4 py-2 text-xs font-bold text-primary uppercase tracking-wider hover:text-primary-dark border-b border-gray-100 mb-1 pb-3"
                              >
                                View All
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                              </a>
                            )}
                            <div class="space-y-0.5">
                              {link.links.map((sublink) => (
                                <a
                                  href={sublink.href}
                                  class="group/item flex items-center gap-3 px-4 py-3 hover:bg-neutral transition-all border-l-2 border-transparent hover:border-primary-light"
                                >
                                  {sublink.icon && (
                                    <div class="flex-shrink-0 w-8 h-8 bg-neutral flex items-center justify-center group-hover/item:bg-primary-light transition-colors">
                                      <Icon
                                        name={sublink.icon}
                                        class="w-4 h-4 text-primary group-hover/item:text-white transition-colors"
                                      />
                                    </div>
                                  )}
                                  <div class="flex-1 min-w-0">
                                    <div class="text-sm font-semibold text-gray-800 group-hover/item:text-primary transition-colors">
                                      {sublink.text}
                                    </div>
                                    {sublink.description && (
                                      <div class="text-xs text-gray-500 mt-0.5 line-clamp-1">
                                        {sublink.description}
                                      </div>
                                    )}
                                  </div>
                                  <svg class="w-3.5 h-3.5 text-gray-300 group-hover/item:text-primary-light transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                  </svg>
                                </a>
                              ))}
                            </div>
                          </div>
                        </div>
                      </div>
                    )}
                  </>
                ) : (
                  <a
                    href={link.href}
                    class="px-4 py-2 font-semibold text-gray-700 hover:text-primary"
                  >
                    {link.text}
                  </a>
                )}
              </div>
            ))
          }
        </nav>

        <!-- CTA Actions -->
        {
          actions.length > 0 && (
            <div class="flex items-center gap-3">
              {actions.map((action) => (
                <a
                  href={action.href}
                  class="btn-modern"
                >
                  <span class="btn-modern-content">{action.text}</span>
                  <span class="btn-modern-icon">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          )
        }
      </div>

      <!-- Mobile menu button -->
      <div class="mobile-menu-toggle">
        <button
          type="button"
          id="mobile-menu-toggle"
          class="ml-1.5 text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-4 focus:ring-gray-200 text-sm p-2.5 inline-flex items-center transition"
          aria-label="Toggle Menu"
          aria-expanded="false"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-200 bg-white shadow-lg"
  >
    <div
      class="px-4 pt-4 pb-6 space-y-2 max-h-[calc(100vh-64px)] overflow-y-auto"
    >
      {
        links.map((link) => (
          <div>
            {link.links && link.links.length > 0 ? (
              <>
                <button
                  class="mobile-dropdown-btn w-full flex items-center justify-between px-4 py-3 text-base font-semibold text-gray-900 hover:bg-neutral transition-all"
                  aria-label={`${link.text} menu`}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {link.text}
                  <svg
                    class="h-5 w-5 transform transition-transform text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                </button>
                <div class="mobile-dropdown-content mt-2 space-y-1 transition-all duration-300 ease-in-out overflow-hidden max-h-0">
                  {link.href && (
                    <a
                      href={link.href}
                      class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary"
                    >
                      Overview
                    </a>
                  )}
                  {link.links.map((sublink) => (
                    <div>
                      {sublink.links && sublink.links.length > 0 ? (
                        <>
                          <button
                            class="mobile-dropdown-btn w-full flex items-center justify-between px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary"
                            aria-label={`${sublink.text} submenu`}
                            aria-haspopup="true"
                            aria-expanded="false"
                          >
                            {sublink.text}
                            <svg
                              class="h-4 w-4 transform transition-transform"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"
                              />
                            </svg>
                          </button>
                          <div class="mobile-dropdown-content mt-2 ml-2 space-y-1 transition-all duration-300 ease-in-out overflow-hidden max-h-0">
                            {sublink.links.map((nestedLink) => (
                              <a
                                href={nestedLink.href}
                                class="flex items-center gap-2 px-3 py-2 text-xs text-gray-500 hover:bg-gray-50 hover:text-primary"
                              >
                                {nestedLink.icon && (
                                  <Icon
                                    name={nestedLink.icon}
                                    class="w-3.5 h-3.5 flex-shrink-0"
                                  />
                                )}
                                <span>{nestedLink.text}</span>
                              </a>
                            ))}
                          </div>
                        </>
                      ) : (
                        <a
                          href={sublink.href}
                          class="block px-3 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-primary"
                        >
                          {sublink.text}
                        </a>
                      )}
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={link.href}
                class="block px-3 py-2 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-primary"
              >
                {link.text}
              </a>
            )}
          </div>
        ))
      }

      {
        actions.length > 0 && (
          <div class="pt-4 mt-2 border-t border-gray-200 px-4">
            {actions.map((action) => (
              <a
                href={action.href}
                class="block w-full text-center px-6 py-3 text-sm font-semibold bg-primary text-white hover:bg-primary-dark transition-all duration-300"
              >
                {action.text}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggleButton = document.getElementById("mobile-menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (!toggleButton || !mobileMenu) return;

    toggleButton.addEventListener("click", () => {
      const isExpanded = toggleButton.getAttribute("aria-expanded") === "true";
      toggleButton.setAttribute("aria-expanded", (!isExpanded).toString());
      mobileMenu.classList.toggle("hidden");
    });

    document.querySelectorAll(".mobile-dropdown-btn").forEach((button) => {
      button.addEventListener("click", (e) => {
        e.preventDefault();
        const content = button.nextElementSibling;
        const svg = button.querySelector("svg");
        const parentDiv = button.parentElement;

        // Toggle current dropdown with smooth transition
        const contentEl = content as HTMLElement;
        const isOpen =
          contentEl?.style.maxHeight && contentEl.style.maxHeight !== "0px";

        if (!isOpen) {
          // Close only sibling dropdowns when opening (same level)
          const siblings = parentDiv?.parentElement?.children;
          if (siblings) {
            Array.from(siblings).forEach((sibling) => {
              if (sibling !== parentDiv) {
                const siblingContent = sibling.querySelector(
                  ":scope > .mobile-dropdown-content"
                );
                const siblingArrow = sibling.querySelector(
                  ":scope > .mobile-dropdown-btn svg"
                );
                if (siblingContent) {
                  (siblingContent as HTMLElement).style.maxHeight = "0px";
                }
                if (siblingArrow) {
                  siblingArrow.classList.remove("rotate-180");
                }
              }
            });
          }

          contentEl.style.maxHeight = contentEl.scrollHeight + "px";
          svg?.classList.add("rotate-180");

          // Update parent heights when nested dropdown opens
          const updateParentHeights = () => {
            let parent = contentEl.parentElement?.closest(
              ".mobile-dropdown-content"
            ) as HTMLElement;
            while (parent) {
              parent.style.maxHeight = parent.scrollHeight + "px";
              parent = parent.parentElement?.closest(
                ".mobile-dropdown-content"
              ) as HTMLElement;
            }
          };

          setTimeout(updateParentHeights, 10);
          setTimeout(updateParentHeights, 320);
        } else {
          contentEl.style.maxHeight = "0px";
          svg?.classList.remove("rotate-180");

          // Update parent heights when nested dropdown closes
          setTimeout(() => {
            let parent = contentEl.parentElement?.closest(
              ".mobile-dropdown-content"
            ) as HTMLElement;
            while (parent) {
              parent.style.maxHeight = parent.scrollHeight + "px";
              parent = parent.parentElement?.closest(
                ".mobile-dropdown-content"
              ) as HTMLElement;
            }
          }, 310);
        }
      });
    });
  }

  function initSmartDropdowns() {
    // Hover-based dropdown navigation
    const dropdownContainers = document.querySelectorAll("[data-dropdown]");

    dropdownContainers.forEach((container) => {
      const dropdown = container.querySelector(".dropdown-menu");
      const arrow = container.querySelector(".dropdown-arrow");

      if (!dropdown) return;

      let closeTimeout: ReturnType<typeof setTimeout> | null = null;

      const openDropdown = () => {
        // Clear any pending close timeout
        if (closeTimeout) {
          clearTimeout(closeTimeout);
          closeTimeout = null;
        }

        // Close all other dropdowns
        document.querySelectorAll(".dropdown-menu").forEach((menu) => {
          if (menu !== dropdown) {
            menu.classList.remove(
              "opacity-100",
              "visible",
              "pointer-events-auto"
            );
            menu.classList.add("opacity-0", "invisible", "pointer-events-none");
          }
        });

        // Reset all other arrows
        document.querySelectorAll(".dropdown-arrow").forEach((svg) => {
          if (svg !== arrow) {
            svg.classList.remove("rotate-180");
          }
        });

        // Open current dropdown
        dropdown.classList.remove(
          "opacity-0",
          "invisible",
          "pointer-events-none"
        );
        dropdown.classList.add("opacity-100", "visible", "pointer-events-auto");
        arrow?.classList.add("rotate-180");
      };

      const closeDropdown = () => {
        closeTimeout = setTimeout(() => {
          dropdown.classList.remove(
            "opacity-100",
            "visible",
            "pointer-events-auto"
          );
          dropdown.classList.add(
            "opacity-0",
            "invisible",
            "pointer-events-none"
          );
          arrow?.classList.remove("rotate-180");
        }, 100);
      };

      // Open dropdown on hover over container
      container.addEventListener("mouseenter", openDropdown);

      // Close dropdown when leaving container
      container.addEventListener("mouseleave", closeDropdown);

      // Keep dropdown open when hovering over it
      dropdown.addEventListener("mouseenter", () => {
        if (closeTimeout) {
          clearTimeout(closeTimeout);
          closeTimeout = null;
        }
      });

      // Close dropdown when leaving the dropdown menu
      dropdown.addEventListener("mouseleave", closeDropdown);
    });
  }

  function initShrinkHeader() {
    // Header is static — no scroll behavior
  }

  // Re-initialize on every navigation (View Transitions swap the DOM)
  document.addEventListener("astro:page-load", () => {
    initMobileMenu();
    initSmartDropdowns();
    initShrinkHeader();
  });
</script>

<style>
  /* Desktop navigation - hidden on mobile, visible on desktop */
  .desktop-nav {
    display: none;
  }
  
  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
  }
  
  /* Mobile menu button - visible on mobile, hidden on desktop */
  .mobile-menu-toggle {
